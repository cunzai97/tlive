# TLive Configuration
# Copy to ~/.tlive/config.env
# chmod 600 ~/.tlive/config.env

# Core
TL_PORT=8080
TL_TOKEN=your-token-here

# Feishu
TL_FS_APP_ID=
TL_FS_APP_SECRET=
TL_FS_ALLOWED_USERS=
TL_FS_VERIFICATION_TOKEN=
TL_FS_ENCRYPT_KEY=
TL_FS_WEBHOOK_PORT=9100
# Pin newly-created Feishu topic entry messages to the chat Pin list.
# Set to false to disable.
TL_FS_AUTO_PIN_TOPIC=true

TL_DEFAULT_WORKDIR=
TL_DEFAULT_MODEL=

# Agent provider: claude or codex
TL_PROVIDER=claude

# Codex provider options (used when TL_PROVIDER=codex)
# TL_CODEX_MODEL=
# TL_CODEX_PATH=
# TL_CODEX_SANDBOX_MODE=workspace-write
# TL_CODEX_APPROVAL_POLICY=on-request
# TL_CODEX_SKIP_GIT_REPO_CHECK=false
# TL_CODEX_REASONING_EFFORT=
# TL_CODEX_NETWORK_ACCESS=
# TL_CODEX_WEB_SEARCH=

# Buttons shown after a task completes.
# Supported: home,new,help,perm,none
TL_DONE_BUTTONS=home

# Provider API keys (optional — set here or as env vars)
# Non-TL_ vars in this file are injected into process.env at startup.
# ANTHROPIC_API_KEY=sk-ant-...
# CODEX_API_KEY=sk-...

# Agent provider settings sources to load in bridge mode (comma-separated)
#   user    — ~/.claude/settings.json (auth, API key, model overrides)
#   project — .claude/settings.json + CLAUDE.md + project MCP config
#   local   — .claude/settings.local.json (developer overrides)
# Default: user (only global auth/model config)
# Set empty to run in full isolation mode
# Recommended: user,project,local (loads all settings)
TL_AGENT_SETTINGS=user,project,local
# Legacy alias accepted for existing configs: TL_CLAUDE_SETTINGS

# Remote server/client split (optional)
# On the Feishu bot machine:
# TL_REMOTE_SERVER_ENABLED=true
# TL_LOCAL_CLIENT_ENABLED=true
# TL_REMOTE_SERVER_PORT=8787
# TL_REMOTE_SERVER_PATH=/tlive
# TL_REMOTE_TOKEN=change-this-token
# TL_REMOTE_PROVIDERS=claude,codex
#
# On worker machines:
# TL_REMOTE_SERVER_URL=ws://your-server:8787/tlive
# TL_REMOTE_TOKEN=change-this-token
# TL_REMOTE_CLIENT_ID=
# TL_REMOTE_CLIENT_NAME=
# TL_REMOTE_CLIENT_PROVIDERS=claude,codex
# TL_REMOTE_WORKSPACES=/path/to/project
# TL_REMOTE_MAX_CONCURRENCY=1
