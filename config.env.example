# TLive Configuration
# Reference for ~/.tlive/server.env and ~/.tlive/client.env.
# Runtime reads role-specific files only.
# Existing ~/.tlive/config.env is auto-split if either role file is missing.
# chmod 600 ~/.tlive/*.env

# ~/.tlive/server.env on the Feishu bot machine:
TL_TOKEN=your-token-here

# Feishu
TL_FS_APP_ID=
TL_FS_APP_SECRET=
TL_FS_ALLOWED_USERS=
TL_FS_VERIFICATION_TOKEN=
TL_FS_ENCRYPT_KEY=
# Pin newly-created Feishu topic entry messages to the chat Pin list.
# Set to false to disable.
TL_FS_AUTO_PIN_TOPIC=true

# Buttons shown after a task completes.
# Supported: home,new,help,perm,none
TL_DONE_BUTTONS=home

# HTTP MCP endpoint for agent callbacks (enabled by default)
# TL_MCP_ENABLED=true
# TL_MCP_PORT=8081
# TL_MCP_PATH=/mcp
# TL_MCP_TOKEN=
# TL_MCP_MAX_FILE_MB=20

# TL_REMOTE_SERVER_PORT=8787
# TL_REMOTE_SERVER_PATH=/tlive
# TL_REMOTE_TOKEN=change-this-token
#
# ~/.tlive/client.env on worker machines:
# TL_REMOTE_SERVER_URL=ws://your-server:8787/tlive
# TL_REMOTE_TOKEN=change-this-token
# TL_PROVIDER=claude
# TL_DEFAULT_MODEL=
# TL_REMOTE_CLIENT_ID=
# TL_REMOTE_CLIENT_NAME=
# TL_REMOTE_CLIENT_NOTE=
# TL_DEFAULT_WORKDIR=/path/to/default/project
# Optional quick directories shown in /home. They do not limit /cd.
# TL_REMOTE_WORKSPACES=/path/to/project-a,/path/to/project-b
#
# Agent provider settings sources (comma-separated)
#   user    — ~/.claude/settings.json (auth, API key, model overrides)
#   project — .claude/settings.json + CLAUDE.md + project MCP config
#   local   — .claude/settings.local.json (developer overrides)
# TL_AGENT_SETTINGS=user,project,local
#
# Codex provider options
# TL_CODEX_MODEL=
# TL_CODEX_PATH=
# TL_CODEX_SANDBOX_MODE=workspace-write
# TL_CODEX_APPROVAL_POLICY=on-request
# TL_CODEX_SKIP_GIT_REPO_CHECK=false
# TL_CODEX_REASONING_EFFORT=
# TL_CODEX_NETWORK_ACCESS=
# TL_CODEX_WEB_SEARCH=
#
# Provider API keys (optional; set here or as shell env vars)
# Non-TL_ vars in client.env are injected into process.env at startup.
# ANTHROPIC_API_KEY=sk-ant-...
# CODEX_API_KEY=sk-...
